{
  "name": "@scout/desktopapp",
  "private": true,
  "version": "0.1.0",
  "description": "Scout desktop shell for JAMARQ's deterministic web presence market scanner.",
  "author": "JAMARQ",
  "type": "module",
  "main": "./scripts/main.mjs",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "start": "node ./scripts/start.mjs",
    "build": "tsc -p tsconfig.json --noEmit",
    "prepare:runtime": "node ./scripts/prepare-runtime.mjs",
    "dist:mac": "pnpm run prepare:runtime && electron-builder --mac dir dmg zip --publish never",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "pnpm run build && node ./scripts/verify.mjs"
  },
  "dependencies": {
    "@scout/config": "workspace:*"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.12"
  },
  "build": {
    "appId": "co.jamarq.scout.desktop",
    "productName": "Scout by JAMARQ",
    "artifactName": "Scout-${version}-${arch}.${ext}",
    "directories": {
      "output": "../../dist/desktop"
    },
    "files": [
      "package.json",
      "scripts/**/*"
    ],
    "extraResources": [
      {
        "from": ".desktop-runtime",
        "to": "desktop-runtime",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dir",
        "dmg",
        "zip"
      ]
    }
  }
}
