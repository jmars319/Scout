{
  "name": "@scout/webapp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "node --no-warnings --experimental-strip-types --experimental-specifier-resolution=node ./src/scripts/worker.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "pnpm run typecheck && pnpm run build"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.0.0",
    "@scout/api-contracts": "workspace:*",
    "@scout/config": "workspace:*",
