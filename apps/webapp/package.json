    "@scout/privacy": "workspace:*",
    "@scout/ui": "workspace:*",
    "@scout/validation": "workspace:*",
    "cheerio": "^1.2.0",
    "next": "^16.2.1",
    "playwright": "^1.58.0",
    "postgres": "^3.4.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.0.0"
  }
}
